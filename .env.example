# ═══════════════════════════════════════════════════
# Trump Monitor v2 — Configuration
# ═══════════════════════════════════════════════════

# ── Telegram ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# Optional: topic/thread ID for forum-style groups
TELEGRAM_THREAD_ID=

# ── Truth Social ───────────────────────────────────
# Username to monitor (without @)
TRUTHSOCIAL_USERNAME=realDonaldTrump

# Polling interval in seconds (default: 60)
# WebSocket provides near real-time (1-5 sec), this is for API fallback polling
POLL_INTERVAL_SECONDS=60

# ── Proxy (optional but recommended) ───────────────
# Cloudflare blocks cloud provider IPs. Use a proxy to bypass.
# Examples:
#   http://user:pass@proxy.example.com:8080
#   socks5://user:pass@proxy.example.com:1080
#   http://proxy.example.com:3128
PROXY_URL=

# ── Optional: Truth Social credentials ─────────────
# For truthbrush library (better API access, handles Cloudflare)
# Leave empty for anonymous access (public posts only)
TRUTHSOCIAL_LOGIN_USERNAME=
TRUTHSOCIAL_LOGIN_PASSWORD=

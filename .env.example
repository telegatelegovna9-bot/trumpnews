# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Thread/Topic ID (для групп с темами/ветками, опционально)
# Узнать: напиши боту в нужной теме, потом открой
# https://api.telegram.org/bot<TOKEN>/getUpdates
# Найди "message_thread_id" в ответе
TELEGRAM_THREAD_ID=

# === Truth Social ===
# Username to monitor (without @)
TRUTHSOCIAL_USERNAME=realDonaldTrump

# Poll interval in minutes (default: 5)
POLL_INTERVAL_MINUTES=5
